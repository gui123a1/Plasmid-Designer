# Plasmid Designer 环境配置
# 安装脚本会自动生成 .env，此处仅作参考

# ========== 存储 ==========
# database: SQLite（默认）或 PostgreSQL
STORAGE_MODE=database

# ========== 数据库 ==========
# SQLite 模式（默认，零外部依赖）
DATABASE_URL=sqlite:////opt/plasmid-designer/plasmid_designer.db

# PostgreSQL 模式（取消注释并注释掉上面 SQLite 行）
# DATABASE_URL=postgresql://plasmid:YOUR_PASSWORD@localhost/plasmid_designer

# ========== Redis ==========
# 直接部署默认关闭，无需 Redis 服务
REDIS_ENABLED=false

# ========== 安全 ==========
# JWT 密钥 — 生产环境务必使用强随机字符串
# 可用: openssl rand -hex 32
SECRET_KEY=change_this_in_production

# ========== 调试 ==========
DEBUG=false
LOG_LEVEL=INFO
